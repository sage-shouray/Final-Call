# ============================================================
# DocParser — Environment Variables
# Copy to .env and fill in your values before starting.
# NEVER commit .env to source control.
# ============================================================

# ── App ──────────────────────────────────────────────────────
ENV=development
DEBUG=false
SECRET_KEY=replace-with-a-long-random-string

# ── PostgreSQL ────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docparser
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6379/0
REDIS_PASSWORD=changeme
CELERY_BROKER_URL=redis://:changeme@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:changeme@localhost:6379/2

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── SAP ───────────────────────────────────────────────────────
SAP_BASE_URL=https://your-sap-host.example.com
SAP_CLIENT=100
SAP_USERNAME=your_sap_username
SAP_PASSWORD=your_sap_password
SAP_TIMEOUT_SECONDS=30

# ── Google AI (Gemini) ────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── AWS / S3-compatible Storage ───────────────────────────────
S3_BUCKET=docparser-uploads
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=us-east-1
# Uncomment for MinIO or other S3-compatible providers:
# S3_ENDPOINT_URL=http://localhost:9000

# ── Observability ─────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
LOG_LEVEL=INFO

# ── Limits ───────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
PROCESSING_CONCURRENCY=4
